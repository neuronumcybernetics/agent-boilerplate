{
  "agent_meta": {
    "agent_id": "",
    "version": "1.0.0",
    "name": "CRM Agent",
    "description": "Manages contacts, interactions, and deals in a CRM",
    "audience": "private",
    "logo": "https://neuronum.net/static/logo_new.png"
  },
  "skills": [
    {
      "handle": "lookup_contact",
      "description": "Find a contact by name or email and return their profile, status, and last interaction",
      "examples": ["find contact John Smith", "look up john@acme.com", "who is Sarah from Acme?"],
      "stream": false,
      "input_schema": {
        "properties": {
          "query": {"type": "string", "description": "Name, email, or company to search for"}
        },
        "required": ["query"]
      }
    },
    {
      "handle": "create_contact",
      "description": "Add a new contact to the CRM",
      "examples": ["add contact Jane Doe from Acme, jane@acme.com", "create a new contact for our new lead"],
      "stream": false,
      "input_schema": {
        "properties": {
          "name": {"type": "string", "description": "Full name"},
          "email": {"type": "string", "description": "Email address"},
          "company": {"type": "string", "description": "Company name"},
          "phone": {"type": "string", "description": "Phone number"},
          "status": {"type": "string", "description": "Contact status: lead, prospect, customer, churned"},
          "notes": {"type": "string", "description": "Additional notes"}
        },
        "required": ["name"]
      }
    },
    {
      "handle": "log_interaction",
      "description": "Log a call, email, or meeting against a contact",
      "examples": ["log a call with John about Q3 renewal", "record that I emailed sarah@acme.com today"],
      "stream": false,
      "input_schema": {
        "properties": {
          "contact_query": {"type": "string", "description": "Name or email of the contact"},
          "type": {"type": "string", "description": "Interaction type: call, email, meeting, note"},
          "summary": {"type": "string", "description": "What was discussed or agreed"},
          "next_action": {"type": "string", "description": "Follow-up action if any"}
        },
        "required": ["contact_query", "type", "summary"]
      }
    },
    {
      "handle": "get_pipeline",
      "description": "Return all open deals with their status, value, and next action",
      "examples": ["show me the pipeline", "what deals are open?", "list all prospects"],
      "stream": false,
      "input_schema": {
        "properties": {
          "status": {"type": "string", "description": "Filter by status: lead, prospect, customer, churned, or all"},
          "limit": {"type": "integer", "description": "Max contacts to return"}
        },
        "required": []
      }
    }
  ],
  "auth": [],
  "legals": {
    "terms": "https://url_to_your/legals",
    "privacy_policy": "https://url_to_your/legals"
  }
}
