{
  "agent_meta": {
    "agent_id": "",
    "version": "1.0.0",
    "name": "Knowledge Agent",
    "description": "Searches and manages a knowledge base",
    "audience": "private",
    "logo": "https://neuronum.net/static/logo_new.png"
  },
  "skills": [
    {
      "handle": "search_knowledge",
      "description": "Search the knowledge base using full-text search",
      "examples": ["find our refund policy", "search for onboarding docs"],
      "stream": false,
      "input_schema": {
        "properties": {
          "query": {"type": "string", "description": "Search query"},
          "limit": {"type": "integer", "description": "Max results to return"},
          "offset": {"type": "integer", "description": "Pagination offset"}
        },
        "required": ["query"]
      }
    },
    {
      "handle": "get_entry",
      "description": "Retrieve a single knowledge entry by ID with full content",
      "examples": ["get entry 3", "show me knowledge entry 7"],
      "stream": false,
      "input_schema": {
        "properties": {
          "entry_id": {"type": "integer", "description": "The entry ID"}
        },
        "required": ["entry_id"]
      }
    },
    {
      "handle": "add_entry",
      "description": "Add a new entry to the knowledge base",
      "examples": ["add a knowledge entry about our refund policy"],
      "stream": false,
      "input_schema": {
        "properties": {
          "title": {"type": "string", "description": "Entry title"},
          "content": {"type": "string", "description": "Entry content"},
          "tags": {"type": "string", "description": "Comma-separated tags"}
        },
        "required": ["title", "content"]
      }
    },
    {
      "handle": "update_entry",
      "description": "Update an existing knowledge entry by ID",
      "examples": ["update entry 3 to include 30-day returns"],
      "stream": false,
      "input_schema": {
        "properties": {
          "entry_id": {"type": "integer", "description": "The entry ID to update"},
          "title": {"type": "string", "description": "New title"},
          "content": {"type": "string", "description": "New content"},
          "tags": {"type": "string", "description": "New comma-separated tags"}
        },
        "required": ["entry_id"]
      }
    },
    {
      "handle": "delete_entry",
      "description": "Delete a knowledge entry by ID",
      "examples": ["delete entry 5"],
      "stream": false,
      "input_schema": {
        "properties": {
          "entry_id": {"type": "integer", "description": "The entry ID to delete"}
        },
        "required": ["entry_id"]
      }
    },
    {
      "handle": "list_entries",
      "description": "List recent knowledge entries",
      "examples": ["list all knowledge entries", "show me recent entries"],
      "stream": false,
      "input_schema": {
        "properties": {
          "limit": {"type": "integer", "description": "Max entries to return"},
          "offset": {"type": "integer", "description": "Pagination offset"}
        },
        "required": []
      }
    }
  ],
  "legals": {
    "terms": "https://url_to_your/legals",
    "privacy_policy": "https://url_to_your/legals"
  }
}
